PORT=4000
NODE_ENV=production
MONGO_URI=mongodb://127.0.0.1:27017/dancetime

JWT_SECRET=replace_me_with_long_random_string
JWT_EXPIRES_IN=7d
QR_SECRET=replace_me_with_another_long_random_string

FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:5173,https://your-frontend.vercel.app
BACKEND_URL=http://localhost:4000

# Preferred email provider for Railway and hosted deployments
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM="DanceTime <onboarding@your-domain.com>"
MAIL_PROVIDER=auto
MAIL_LOG_FALLBACK=true

# Optional SMTP fallback for local use or other hosts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=YOUR_GMAIL@gmail.com
SMTP_PASS=APP_PASSWORD_16_CHARS
SMTP_FROM="DanceTime <YOUR_GMAIL@gmail.com>"

# Temporary Railway workaround:
# MAIL_PROVIDER=log
# This disables real delivery and prints the whole email payload into Railway logs.
